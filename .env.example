# Port for the application (default: 3000)
PORT=3000
# Authentication secret (used by better-auth)
BETTER_AUTH_SECRET="change-me-to-a-random-secret"
# The name of the instance (shown in UI)
INSTANCE_NAME="Voy"
# The base URL of the site (used for auth redirects, must match the PORT)
SITE_URL="http://localhost:3000"
# SearXNG configuration
SEARXNG_SECRET="change-me-to-a-random-secret"

# Logging configuration
# Valid values: trace, debug, info, warn, error, fatal, silent
LOG_LEVEL="info"
# Pretty logs are useful locally, keep false in production
LOG_PRETTY="false"
# Optional comma-separated redact paths override
# LOG_REDACT_PATHS="password,token,authorization,headers.cookie"
